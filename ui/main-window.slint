import { StandardTableView, GroupBox, Button, ProgressIndicator, LineEdit, ComboBox, CheckBox } from "std-widgets.slint";

export component MainWindow inherits Window {
    title: "RapidChecksum";
    preferred-width: 900px;
    preferred-height: 650px;
    min-width: 700px;
    min-height: 500px;

    // Exposed properties for the Rust side to read/write
    in-out property <int> selected-row: -1;

    // Table data — set from Rust via set_file_rows()
    in-out property <[[StandardListViewItem]]> file-rows: [[]];

    // Table columns — set from Rust based on enabled algorithms
    in-out property <[TableColumn]> table-columns: [
        { title: "File", min-width: 150px, width: 200px },
        { title: "CRC32", min-width: 80px, width: 90px },
        { title: "SHA1", min-width: 100px, width: 340px },
        { title: "SHA256", min-width: 100px, width: 520px },
        { title: "SHA512", min-width: 100px, width: 520px },
        { title: "Info", min-width: 100px, width: 180px },
    ];

    // Selected file details for the Results group
    in-out property <string> result-filename: "";
    in-out property <string> result-crc32: "";
    in-out property <string> result-sha1: "";
    in-out property <string> result-sha256: "";
    in-out property <string> result-sha512: "";
    in-out property <string> result-info: "";

    // Progress (0.0 to 1.0)
    in-out property <float> file-progress: 0.0;
    in-out property <float> global-progress: 0.0;
    in-out property <string> status-text: "Ready";
    in-out property <bool> is-hashing: false;

    // Number of files in the list — controls Start button enabled state
    in-out property <int> file-count: 0;

    // Callbacks from UI to Rust
    callback open-files();
    callback start-hashing();
    callback exit-app();
    callback cancel-hashing();
    callback create-sfv-file();
    callback create-sha1-file();
    callback create-sha256-file();
    callback create-sha512-file();
    callback row-selected(int);
    callback clear-list();
    callback remove-selected();
    callback sort-ascending(int);
    callback sort-descending(int);
    callback copy-filepath();
    callback copy-hash();
    callback open-containing-folder();
    callback open-settings();
    callback settings-changed(bool, bool, bool, bool);

    // Settings — algorithm toggles (synced from Rust on startup)
    in-out property <bool> setting-crc32: true;
    in-out property <bool> setting-sha1: true;
    in-out property <bool> setting-sha256: true;
    in-out property <bool> setting-sha512: true;
    in-out property <bool> settings-visible: false;

    VerticalLayout {
        padding: 8px;
        spacing: 6px;

        // Main file table — fills available space
        ctx-menu := ContextMenuArea {
            vertical-stretch: 1;

            Menu {
                MenuItem {
                    title: "Copy Filepath";
                    enabled: root.selected-row >= 0;
                    activated => { root.copy-filepath(); }
                }
                MenuItem {
                    title: "Copy Hash";
                    enabled: root.selected-row >= 0;
                    activated => { root.copy-hash(); }
                }
                MenuItem {
                    title: "Show in File Manager";
                    enabled: root.selected-row >= 0;
                    activated => { root.open-containing-folder(); }
                }
            }

            table := StandardTableView {
                width: 100%;
                height: 100%;

                columns: root.table-columns;

                rows: root.file-rows;

                current-row-changed(row-index) => {
                    root.selected-row = row-index;
                    root.row-selected(row-index);
                }
                sort-ascending(col) => {
                    root.sort-ascending(col);
                }
                sort-descending(col) => {
                    root.sort-descending(col);
                }
                row-pointer-event(row-index, event, mouse-pos) => {
                    if (event.kind == PointerEventKind.up && event.button == PointerEventButton.right) {
                        root.selected-row = row-index;
                        root.row-selected(row-index);
                        ctx-menu.show({x: mouse-pos.x, y: mouse-pos.y + self.absolute-position.y - ctx-menu.absolute-position.y});
                    }
                }
            }
        }

        // Results group box — shows details for selected file
        GroupBox {
            title: "Results";
            vertical-stretch: 0;

            VerticalLayout {
                spacing: 4px;
                padding: 4px;

                HorizontalLayout {
                    spacing: 8px;
                    Text { text: "File:"; width: 55px; vertical-alignment: center; }
                    LineEdit { text: root.result-filename; read-only: true; horizontal-stretch: 1; }
                }
                HorizontalLayout {
                    spacing: 8px;
                    Text { text: "CRC32:"; width: 55px; vertical-alignment: center; }
                    LineEdit { text: root.result-crc32; read-only: true; horizontal-stretch: 1; font-size: 11px; }
                }
                HorizontalLayout {
                    spacing: 8px;
                    Text { text: "SHA1:"; width: 55px; vertical-alignment: center; }
                    LineEdit { text: root.result-sha1; read-only: true; horizontal-stretch: 1; font-size: 11px; }
                }
                HorizontalLayout {
                    spacing: 8px;
                    Text { text: "SHA256:"; width: 55px; vertical-alignment: center; }
                    LineEdit { text: root.result-sha256; read-only: true; horizontal-stretch: 1; font-size: 11px; }
                }
                HorizontalLayout {
                    spacing: 8px;
                    Text { text: "SHA512:"; width: 55px; vertical-alignment: center; }
                    LineEdit { text: root.result-sha512; read-only: true; horizontal-stretch: 1; font-size: 11px; }
                }
                HorizontalLayout {
                    spacing: 8px;
                    Text { text: "Info:"; width: 55px; vertical-alignment: center; }
                    LineEdit { text: root.result-info; read-only: true; horizontal-stretch: 1; }
                }
            }
        }

        // Action button row
        HorizontalLayout {
            spacing: 6px;
            vertical-stretch: 0;
            alignment: start;

            Text {
                text: "Create:";
                vertical-alignment: center;
            }
            Button {
                text: "SFV file";
                enabled: !root.is-hashing;
                clicked => { root.create-sfv-file(); }
            }
            Button {
                text: "SHA1 file";
                enabled: !root.is-hashing;
                clicked => { root.create-sha1-file(); }
            }
            Button {
                text: "SHA256 file";
                enabled: !root.is-hashing;
                clicked => { root.create-sha256-file(); }
            }
            Button {
                text: "SHA512 file";
                enabled: !root.is-hashing;
                clicked => { root.create-sha512-file(); }
            }

            Rectangle { horizontal-stretch: 1; }

            Button {
                text: "Clear List";
                enabled: !root.is-hashing;
                clicked => { root.clear-list(); }
            }
            Button {
                text: "Remove Selected";
                enabled: !root.is-hashing;
                clicked => { root.remove-selected(); }
            }
        }

        // Status row
        HorizontalLayout {
            spacing: 8px;
            vertical-stretch: 0;

            Text {
                text: "Status:";
                vertical-alignment: center;
            }
            LineEdit {
                text: root.status-text;
                read-only: true;
                horizontal-stretch: 1;
            }
            Button {
                text: "Cancel";
                visible: root.is-hashing;
                clicked => { root.cancel-hashing(); }
            }
        }

        // Progress bars row
        HorizontalLayout {
            spacing: 8px;
            vertical-stretch: 0;
            height: 20px;

            Text {
                text: "File:";
                vertical-alignment: center;
                width: 30px;
            }
            ProgressIndicator {
                progress: root.file-progress;
                horizontal-stretch: 1;
            }
            Text {
                text: "Total:";
                vertical-alignment: center;
                width: 38px;
            }
            ProgressIndicator {
                progress: root.global-progress;
                horizontal-stretch: 1;
            }
        }

        // Bottom action row
        HorizontalLayout {
            spacing: 8px;
            vertical-stretch: 0;

            Button {
                text: "Settings";
                enabled: !root.is-hashing;
                clicked => {
                    root.settings-visible = true;
                }
            }

            Rectangle { horizontal-stretch: 1; }

            Button {
                text: "Open Files";
                enabled: !root.is-hashing;
                clicked => { root.open-files(); }
            }
            Button {
                text: root.is-hashing ? "Hashing..." : "Start Hashing";
                enabled: !root.is-hashing && root.file-count > 0;
                clicked => { root.start-hashing(); }
            }
            Button {
                text: "Exit";
                clicked => { root.exit-app(); }
            }
        }
    }

    // Settings overlay
    if root.settings-visible : Rectangle {
        width: 100%;
        height: 100%;
        background: #00000040;

        TouchArea {
            // Block clicks from reaching the main UI
        }

        Rectangle {
            x: (root.width - self.width) / 2;
            y: (root.height - self.height) / 2;
            width: 260px;
            height: 250px;
            border-width: 1px;
            border-radius: 6px;
            border-color: #888;
            background: white;

            VerticalLayout {
                padding: 16px;
                spacing: 10px;

                Text {
                    text: "Settings";
                    font-size: 16px;
                    font-weight: 700;
                    horizontal-alignment: center;
                }

                GroupBox {
                    title: "Algorithms";

                    VerticalLayout {
                        spacing: 6px;
                        padding: 4px;

                        cb-crc32 := CheckBox {
                            text: "CRC32";
                            checked: root.setting-crc32;
                        }
                        cb-sha1 := CheckBox {
                            text: "SHA1";
                            checked: root.setting-sha1;
                        }
                        cb-sha256 := CheckBox {
                            text: "SHA256";
                            checked: root.setting-sha256;
                        }
                        cb-sha512 := CheckBox {
                            text: "SHA512";
                            checked: root.setting-sha512;
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: center;

                    Button {
                        text: "OK";
                        clicked => {
                            root.setting-crc32 = cb-crc32.checked;
                            root.setting-sha1 = cb-sha1.checked;
                            root.setting-sha256 = cb-sha256.checked;
                            root.setting-sha512 = cb-sha512.checked;
                            root.settings-changed(
                                cb-crc32.checked,
                                cb-sha1.checked,
                                cb-sha256.checked,
                                cb-sha512.checked
                            );
                            root.settings-visible = false;
                        }
                    }
                    Button {
                        text: "Cancel";
                        clicked => {
                            root.settings-visible = false;
                        }
                    }
                }
            }
        }
    }
}
